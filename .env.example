# Billing — cổng hiển thị trên /billing (phân tách dấu phẩy). Mặc định: MANUAL,VNPAY,MOMO
# Ví dụ chỉ CK + VNPay: VITE_BILLING_GATEWAYS=MANUAL,VNPAY
# VITE_BILLING_GATEWAYS=MANUAL,VNPAY,MOMO

# API
VITE_API_BASE_URL=http://localhost:8080/api
VITE_WS_URL=http://localhost:8080/ws

# OAuth (optional)
VITE_APP_GOOGLE_CLIENT_ID=
VITE_GOOGLE_OAUTH_REDIRECT_URI=

# Staging (Vercel + Railway): see .env.staging.example and docs/deploy/STAGING.md

# SEO — set production domain (no trailing slash). Build sẽ:
#   - inject canonical/og:url/og:image absolute vào index.html
#   - sinh dist/sitemap.xml + ghi Sitemap: <site>/sitemap.xml vào robots.txt
# Ví dụ production: https://sotuci.vn  hoặc staging Vercel: https://salsales-management-web.vercel.app
# VITE_SITE_URL=https://sotuci.vn
# VITE_BRAND_DOMAIN=sotuci

# Đường dẫn ảnh OG (file nằm trong public/). Mặc định trỏ tới og-landing.png.
VITE_OG_IMAGE_PATH=/og-landing.png

# Support contact — dùng cho schema.org ContactPoint trong Organization JSON-LD
VITE_SUPPORT_NAME=Sales Support
VITE_SUPPORT_EMAIL=
VITE_SUPPORT_PHONE=
VITE_SUPPORT_ZALO=
