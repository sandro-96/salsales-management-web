# Vercel → Project → Settings → Environment Variables (Production + Preview)
# Build command: npm run build | Output: dist
# Sau khi đổi biến VITE_* → Redeploy (Vite nhúng lúc build).

# Backend API (Railway public URL + /api)
VITE_API_BASE_URL=https://your-api.up.railway.app/api

# SockJS endpoint (https, not wss)
VITE_WS_URL=https://your-api.up.railway.app/ws

# Google OAuth — Web client; redirect phải là URL Vercel /login, KHÔNG phải Railway
VITE_APP_GOOGLE_CLIENT_ID=
VITE_GOOGLE_OAUTH_REDIRECT_URI=https://salsales-management-web.vercel.app/login

# SEO — URL Vercel cố định (no trailing slash)
VITE_SITE_URL=https://salsales-management-web.vercel.app
VITE_OG_IMAGE_PATH=/og-landing.png
