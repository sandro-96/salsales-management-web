# Vercel → Project → Settings → Environment Variables (Production + Preview)
# Build command: npm run build | Output: dist

# Backend API (Railway / Render public URL + /api)
VITE_API_BASE_URL=https://your-api.up.railway.app/api

# SockJS endpoint (https, not wss)
VITE_WS_URL=https://your-api.up.railway.app/ws

# Google OAuth — same client ID as backend; add origins in Google Cloud Console:
#   https://your-app.vercel.app
#   https://*.vercel.app (if using preview deployments)
VITE_APP_GOOGLE_CLIENT_ID=
VITE_GOOGLE_OAUTH_REDIRECT_URI=https://your-app.vercel.app/login

# SEO — set to your stable Vercel URL (no trailing slash)
VITE_SITE_URL=https://your-app.vercel.app
VITE_OG_IMAGE_PATH=/og-landing.png
